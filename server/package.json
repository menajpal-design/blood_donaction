{
  "name": "bangla-blood-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "dev:reset-port": "npx kill-port 5000 && node src/server.js",
    "start": "node src/server.js",
    "seed:locations": "node src/scripts/seed-locations.js",
    "backfill:upazila-areas": "node src/scripts/backfill-missing-upazila-areas.js",
    "generate:location-data": "node src/scripts/generate-location-dataset.js",
    "build": "echo \"No build step required for server\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@types/whatwg-url": "^11.0.2",
    "basic-auth": "~2.0.1",
    "bcryptjs": "^2.4.3",
    "bd-address-pro": "^1.2.0",
    "brace-expansion": "^1.1.7",
    "bson": "^6.10.4",
    "call-bound": "^1.0.4",
    "callsites": "^3.0.0",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "deep-is": "^0.1.3",
    "dotenv": "^16.5.0",
    "ee-first": "^1.1.1",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "fast-levenshtein": "^2.0.6",
    "forwarded": "^0.2.0",
    "glob": "^7.1.3",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "http-status-codes": "^2.3.0",
    "ignore-by-default": "^1.0.1",
    "ipaddr.js": "^2.3.0",
    "isexe": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.18.1",
    "mongoose": "^8.13.2",
    "morgan": "^1.10.0",
    "zod": "^3.24.2"
